# ============================================================================
# NL2SQL Clinic Intelligence System — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub — it's in .gitignore
# ============================================================================

# LLM PROVIDER SELECTION
# Options: 'gemini', 'groq', 'ollama'
LLM_PROVIDER=gemini

# ============================================================================
# GOOGLE GEMINI (Free tier via AI Studio)
# ============================================================================
# Get free API key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Gemini model selection
# GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# GROQ API (Optional alternative — Llama 3.3 70B)
# ============================================================================
# Free tier available at: https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# OLLAMA LOCAL (Optional — fully free, runs locally)
# ============================================================================
# Install from: https://ollama.ai
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite database file path (relative to project root)
DATABASE_PATH=clinic.db

# ============================================================================
# API CONFIGURATION
# ============================================================================
# FastAPI server settings
API_HOST=0.0.0.0
API_PORT=8000

# Rate limiting (requests per minute per IP)
RATE_LIMIT=10/minute

# Query result cache TTL (minutes)
CACHE_TTL_MINUTES=5

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log directory (created if doesn't exist)
LOG_DIR=logs

# ============================================================================
# STREAMLIT CONFIGURATION (Optional)
# ============================================================================
# Streamlit server settings (run with: streamlit run streamlit_app.py)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# ============================================================================
# AGENT MEMORY
# ============================================================================
# Maximum Q&A pairs stored in agent memory
MAX_MEMORY_ITEMS=100

# ============================================================================
# SECURITY
# ============================================================================
# CORS allowed origins (comma-separated)
# Leave * for development, tighten for production
CORS_ORIGINS=*

# SQL validation — only SELECT queries allowed
ALLOW_SELECT_ONLY=true
